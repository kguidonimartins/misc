<kml xmlns="http://www.opengis.net/kml/2.2">
<Document id="root_doc">
<Schema name="misc_example" id="misc_example">
	<SimpleField name="id" type="int"></SimpleField>
</Schema>
<Folder><name>misc_example</name>
